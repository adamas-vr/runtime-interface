{
	"name": "adamas-bindings",
	"version": "0.1.0",
	"description": "Unity bindings of the adamas project API",
	"main": "library/index.ts",
	"private": true,
	"exports": {
		".": "./library/index.ts",
		"./*": "./library/*"
	},
	"scripts": {
		"compile": "npx cmake-js compile",
		"start": "npx ts-node index.ts",
		"format": "npx prettier . --write"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com:adamas-vr/prefab-interface.git"
	},
	"author": "Adamas VR, Inc.",
	"bugs": {
		"url": "https://github.com/adamas-vr/prefab-interface/issues"
	},
	"homepage": "https://github.com/adamas-vr/prefab-interface#readme",
	"dependencies": {
		"@babylonjs/core": "^8.13.0",
		"@babylonjs/loaders": "^8.13.0",
		"node-addon-api": "^8.4.0"
	},
	"devDependencies": {
		"@types/node": "^24.0.3",
		"cmake-js": "^7.3.1",
		"ts-node": "^10.0.0",
		"tsconfig-paths": "^4.2.0",
		"typescript": "^5.0.0"
	}
}
