{
	"name": "@adamasvr/sdk",
	"version": "0.4.4",
	"description": "Adamas Typescript interface.",
	"keywords": [
		"adamas",
		"vr",
		"sdk",
		"typescript",
		"rendering",
		"physics",
		"networking"
	],
	"license": "BSD-2-Clause",
	"main": "dist/index.js",
	"files": [
		"dist",
		"types",
		"README.md",
		"LICENSE"
	],
	"scripts": {
		"format": "npx prettier . --write",
		"build": "npm run esbuild && npm run build:shared-texture && npm run dts",
		"build:shared-texture": "npx node-gyp rebuild --directory ./native/shared-texture-addon && node ./native/shared-texture-addon/copy-to-dist.js",
		"esbuild": "esbuild library/index.ts --bundle --minify --format=esm --sourcemap --outfile=dist/index.js --platform=node --external:*.node",
		"dts": "dts-bundle-generator --project tsconfig.json -o types/lib.d.ts library/index.ts"
	},
	"repository": {
		"type": "git",
		"url": "git+ssh://git@github.com:adamas-vr/runtime-interface.git"
	},
	"author": "Adamas VR, Inc.",
	"bugs": {
		"url": "https://github.com/adamas-vr/runtime-interface/issues"
	},
	"types": "./types/index.d.ts",
	"homepage": "https://github.com/adamas-vr/runtime-interface#readme",
	"dependencies": {
		"gl-matrix": "^3.4.4"
	},
	"devDependencies": {
		"@types/node": "^24.12.3",
		"dts-bundle-generator": "^9.5.1",
		"esbuild": "^0.28.0",
		"typescript": "^5.0.0"
	}
}
