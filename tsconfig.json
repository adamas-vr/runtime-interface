{
	"compilerOptions": {
		"target": "es2020",
		"moduleResolution": "nodenext",
		"module": "nodenext",
		"resolveJsonModule": true,
		"declaration": true,
		"sourceMap": true,
		"declarationMap": true,
		"typeRoots": ["./node_modules/@types", "./types"], // prevent typechecking in parent node_modules
		"types": ["node"],
		"outDir": "dist",
		"rootDir": "library",
		"strict": true,
		"noEmit": true
	},
	"include": ["./library", "./types"],
	"exclude": ["samples", "index.ts"]
}
